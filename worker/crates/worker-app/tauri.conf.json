{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hydra-worker",
  "version": "0.1.0",
  "identifier": "ai.hydra.worker",
  "build": {
    "frontendDist": "../../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "hydra-worker",
        "width": 980,
        "height": 720,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
