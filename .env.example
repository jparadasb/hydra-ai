# Copy to .env and fill in. Do NOT commit .env.

# Postgres password (used by the postgres service and the coordinator's DATABASE_URL).
POSTGRES_PASSWORD=change-me

# Phoenix endpoint signing key. Generate a 64+ byte secret:
#   mix phx.gen.secret      (or: openssl rand -base64 48)
SECRET_KEY_BASE=replace-with-a-long-random-secret

# Cloudflare Tunnel token from the Zero Trust dashboard (Networks -> Tunnels -> your tunnel).
# In the dashboard, route your public hostname to the service http://coordinator:4000.
TUNNEL_TOKEN=replace-with-your-cloudflare-tunnel-token

# Worker authentication. Each worker derives a stable machine worker_id and a local Ed25519
# device key (private key never leaves the worker); the coordinator pins the public key on
# first contact (trust-on-first-use). Set this to require it and reject any worker without a
# device key — STRONGLY recommended for a public (tunneled) coordinator.
# HYDRA_REQUIRE_DEVICE_AUTH=true

# Optional shared join token (fallback auth for workers that present no device key). Generate:
# openssl rand -hex 32
# HYDRA_JOIN_TOKEN=replace-with-a-long-random-secret

# Optional: DB connection pool size (default 10).
# POOL_SIZE=10
